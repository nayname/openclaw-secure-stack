{
	"$schema": "https://example.org/schemas/intent-execution-plan.v1.json",
	"type": "object",
	"required": [
		"plan_id",
		"execution_mode",
		"created_at",
		"id",
		"category",
		"name",
		"description",
		"user_profile",
		"context",
		"steps",
		"abort_conditions"
	],
	"additionalProperties": false,
	"properties": {
		"id": {
			"type": "string",
			"pattern": "^[a-z0-9_]+\\.[a-z0-9_]+$"
		},
		"category": {
			"type": "string"
		},
		"name": {
			"type": "string",
			"minLength": 3
		},
		"description": {
			"type": "string",
			"minLength": 10
		},
		"plan_id": {
			"type": "string",
			"format": "uuid",
			"description": "Unique identifier for binding, replay protection, and audit correlation."
		},
		"session_id": {
			"type": "string",
			"description": "Optional session binding (if your system has sessions)."
		},
		"created_at": {
			"type": "string",
			"format": "date-time",
			"description": "Plan creation time."
		},
		"expires_at": {
			"type": "string",
			"format": "date-time",
			"description": "Plan TTL — executor must reject if now > expires_at."
		},
		"execution_mode": {
			"type": "string",
			"enum": [
				"preview",
				"execute"
			],
			"description": "preview=validate+render only, execute=may perform side effects."
		},
		"metadata": {
			"$ref": "#/$defs/Metadata",
			"description": "Non-execution metadata for dataset QA and audit."
		},
		"user_profile": {
			"type": "object",
			"required": [
				"id",
				"role",
				"trust_level",
				"team",
				"access_tier"
			],
			"additionalProperties": false,
			"properties": {
				"id": {
					"type": "string"
				},
				"role": {
					"type": "string"
				},
				"trust_level": {
					"type": "string",
					"enum": [
						"low",
						"medium",
						"high"
					]
				},
				"team": {
					"type": "string"
				},
				"access_tier": {
					"type": "string"
				},
				"domain": {
					"type": "string"
				},
				"oncall": {
					"type": "boolean"
				}
			}
		},
		"context": {
			"type": "object",
			"required": [
				"situation",
				"scope",
				"policy",
				"invariants",
				"limits",
				"audit"
			],
			"additionalProperties": false,
			"properties": {
				"situation": {
					"type": "object",
					"required": [
						"scenario",
						"urgency"
					],
					"additionalProperties": false,
					"properties": {
						"scenario": {
							"type": "string"
						},
						"urgency": {
							"type": "string",
							"enum": [
								"low",
								"medium",
								"high",
								"sev1"
							]
						}
					}
				},
				"scope": {
					"type": "object",
					"required": [
						"target_system",
						"environment_scope"
					],
					"additionalProperties": false,
					"properties": {
						"target_system": {
							"type": "string"
						},
						"environment_scope": {
							"type": "string"
						},
						"execution_environment": {
							"type": "string"
						},
						"allowed_systems": {
							"type": "array",
							"items": {
								"type": "string"
							}
						},
						"forbidden_systems": {
							"type": "array",
							"items": {
								"type": "string"
							}
						}
					}
				},
				"policy": {
					"type": "object",
					"required": [
						"execution_constraints",
						"operations",
						"approvals",
						"data_handling",
						"enforcement"
					],
					"additionalProperties": false,
					"properties": {
						"execution_constraints": {
							"type": "string"
						},
						"execution_mode": {
							"type": "string"
						},
						"operations": {
							"type": "object",
							"required": [
								"allow",
								"deny"
							],
							"additionalProperties": false,
							"properties": {
								"allow": {
									"type": "array",
									"items": {
										"type": "string"
									}
								},
								"deny": {
									"type": "array",
									"items": {
										"type": "string"
									}
								}
							}
						},
						"approvals": {
							"type": "object",
							"required": [
								"model"
							],
							"additionalProperties": false,
							"properties": {
								"model": {
									"type": "string"
								},
								"required_references": {
									"type": "array",
									"items": {
										"type": "string"
									}
								},
								"required_incident_reference": {
									"type": "boolean"
								},
								"required_audit_ticket_reference": {
									"type": "boolean"
								}
							}
						},
						"data_handling": {
							"type": "object",
							"required": [
								"data_sensitivity"
							],
							"additionalProperties": false,
							"properties": {
								"data_sensitivity": {
									"type": "string",
									"enum": [
										"public",
										"internal",
										"confidential",
										"regulated"
									]
								},
								"data_access_scope": {
									"type": "object",
									"additionalProperties": false,
									"properties": {
										"allowed_data_domains": {
											"type": "array",
											"items": {
												"type": "string"
											}
										},
										"forbidden_data_domains": {
											"type": "array",
											"items": {
												"type": "string"
											}
										}
									}
								},
								"data_access_limits": {
									"type": "object",
									"additionalProperties": false,
									"properties": {
										"allow_customer_data_access": {
											"type": "boolean"
										},
										"allow_pii_access": {
											"type": "boolean"
										},
										"max_records_viewable": {
											"type": "integer",
											"minimum": 0
										}
									}
								},
								"external_sharing_allowed": {
									"type": "boolean"
								}
							}
						},
						"enforcement": {
							"type": "object",
							"required": [
								"allow_unplanned",
								"max_total_operations",
								"require_sequential"
							],
							"additionalProperties": false,
							"properties": {
								"allow_unplanned": {
									"type": "boolean",
									"const": false,
									"description": "Hard safety: executor must not run tool calls not represented in steps/do."
								},
								"max_total_operations": {
									"type": "integer",
									"minimum": 1,
									"default": 50,
									"description": "Hard cap on total low-level operations across the whole plan."
								},
								"require_sequential": {
									"type": "boolean",
									"default": true,
									"description": "If true, executor must run steps strictly in order and respect depends_on."
								},
								"max_parallelism": {
									"type": "integer",
									"minimum": 1,
									"default": 1,
									"description": "If require_sequential=false, cap parallel execution. Default 1 means effectively sequential."
								},
								"allow": {
									"$ref": "#/$defs/AllowDenyPatterns",
									"description": "Optional global allow patterns for concrete executors (paths/urls/commands/args)."
								},
								"deny": {
									"$ref": "#/$defs/AllowDenyPatterns",
									"description": "Optional global deny patterns (deny overrides allow)."
								}
							}
						}
					}
				},
				"invariants": {
					"type": "object",
					"required": [
						"must_hold",
						"refusal_conditions"
					],
					"additionalProperties": false,
					"properties": {
						"must_hold": {
							"type": "array",
							"items": {
								"type": "string"
							}
						},
						"refusal_conditions": {
							"type": "array",
							"items": {
								"type": "string"
							}
						},
						"preconditions": {
							"type": "array",
							"items": {
								"type": "string"
							}
						}
					}
				},
				"limits": {
					"type": "object",
					"required": [
						"time",
						"blast_radius"
					],
					"additionalProperties": false,
					"properties": {
						"max_execution_time_minutes": {
							"type": "integer",
							"minimum": 1
						},
						"execution": {
							"type": "object",
							"additionalProperties": false,
							"properties": {
								"require_sequential": {
									"type": "boolean",
									"default": false,
									"description": "If true, executor MUST ignore parallel flags and execute one step at a time."
								},
								"max_parallelism": {
									"type": "integer",
									"minimum": 1,
									"default": 1,
									"description": "Hard cap on concurrently executing steps."
								}
							}
						},
						"time": {
							"type": "object",
							"additionalProperties": false,
							"properties": {
								"max_step_duration_minutes": {
									"type": "integer",
									"minimum": 1
								},
								"max_total_duration_minutes": {
									"type": "integer",
									"minimum": 1
								},
								"change_window": {
									"type": "string"
								},
								"time_window_utc": {
									"type": "object",
									"additionalProperties": false,
									"properties": {
										"start_offset_hours_from_now": {
											"type": "integer"
										},
										"end_offset_hours_from_now": {
											"type": "integer"
										}
									}
								}
							}
						},
						"blast_radius": {
							"type": "object",
							"additionalProperties": false,
							"properties": {
								"max_allowed_impact": {
									"type": "string"
								},
								"max_allowed_systems": {
									"type": "array",
									"items": {
										"type": "string"
									}
								},
								"max_concurrent_changes": {
									"type": "integer",
									"minimum": 1
								},
								"max_records_affected_per_step": {
									"type": "integer",
									"minimum": 0
								},
								"max_documents_to_modify_or_version": {
									"type": "integer",
									"minimum": 0
								},
								"max_documents_to_review": {
									"type": "integer",
									"minimum": 0
								},
								"max_campaigns_to_review": {
									"type": "integer",
									"minimum": 0
								},
								"max_affected_accounts": {
									"type": "integer",
									"minimum": 0
								},
								"max_allowed_downtime_minutes": {
									"type": "integer",
									"minimum": 0
								}
							}
						}
					}
				},
				"audit": {
					"type": "object",
					"required": [
						"logging",
						"traceability"
					],
					"additionalProperties": false,
					"properties": {
						"logging": {
							"type": "object",
							"required": [
								"log_level",
								"log_location",
								"log_fields"
							],
							"additionalProperties": false,
							"properties": {
								"log_level": {
									"type": "string"
								},
								"log_location": {
									"type": "string"
								},
								"log_fields": {
									"type": "array",
									"items": {
										"type": "string"
									}
								}
							}
						},
						"traceability": {
							"type": "object",
							"additionalProperties": false,
							"properties": {
								"require_ticket_id_in_all_writes": {
									"type": "boolean"
								},
								"require_timestamp_in_all_writes": {
									"type": "boolean"
								},
								"require_user_id_in_all_writes": {
									"type": "boolean"
								}
							}
						}
					}
				},
				"extensions": {
					"type": "object",
					"description": "Category-specific additional context; executor must ignore unknown namespaces unless explicitly supported.",
					"additionalProperties": true
				}
			}
		},
		"steps": {
			"type": "array",
			"minItems": 1,
			"items": {
				"$ref": "#/$defs/Step"
			}
		},
		"abort_conditions": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "string"
			}
		}
	},
	"$defs": {
		"Step": {
			"type": "object",
			"required": [
				"step",
				"action",
				"inputs",
				"do",
				"verify",
				"on_fail",
				"audit"
			],
			"additionalProperties": false,
			"properties": {
				"step": {
					"type": "integer",
					"minimum": 1
				},
				"depends_on": {
					"type": "array",
					"items": {
						"type": "integer",
						"minimum": 1
					},
					"uniqueItems": true,
					"default": [],
					"description": "Steps that must COMPLETE successfully before this step may start."
				},
				"parallel": {
					"type": "boolean",
					"default": false,
					"description": "If true, this step MAY run concurrently with other eligible steps."
				},
				"max_invocations": {
					"type": "integer",
					"minimum": 1,
					"default": 1,
					"description": "Maximum number of times this step may be executed."
				},
				"action": {
					"type": "string",
					"minLength": 3
				},
				"inputs": {
					"type": "object",
					"required": [
						"required",
						"optional"
					],
					"additionalProperties": false,
					"properties": {
						"required": {
							"type": "array",
							"items": {
								"$ref": "#/$defs/InputSpec"
							}
						},
						"optional": {
							"type": "array",
							"items": {
								"$ref": "#/$defs/InputSpec"
							}
						}
					}
				},
				"do": {
					"type": "object",
					"required": [
						"operation_type",
						"target",
						"parameters"
					],
					"additionalProperties": false,
					"properties": {
						"operation_type": {
							"type": "string"
						},
						"target": {
							"type": "string"
						},
						"parameters": {
							"type": "object",
							"additionalProperties": true
						},
						"allowed_operations": {
							"type": "array",
							"items": {
								"type": "string"
							}
						},
						"disallowed_operations": {
							"type": "array",
							"items": {
								"type": "string"
							}
						}
					}
				},
				"verify": {
					"type": "object",
					"required": [
						"checks"
					],
					"additionalProperties": false,
					"properties": {
						"checks": {
							"type": "array",
							"minItems": 1,
							"items": {
								"$ref": "#/$defs/CheckSpec"
							}
						}
					}
				},
				"on_fail": {
					"type": "object",
					"required": [
						"behavior",
						"refuse_if"
					],
					"additionalProperties": false,
					"properties": {
						"behavior": {
							"type": "string",
							"enum": [
								"abort_intent",
								"abort_step",
								"mark_failed_and_continue",
								"complete_with_warning"
							]
						},
						"refuse_if": {
							"type": "array",
							"items": {
								"type": "string"
							}
						},
						"required_log_entries": {
							"type": "array",
							"items": {
								"type": "string"
							}
						}
					}
				},
				"audit": {
					"type": "object",
					"required": [
						"record_outputs"
					],
					"additionalProperties": false,
					"properties": {
						"record_outputs": {
							"type": "array",
							"items": {
								"$ref": "#/$defs/OutputSpec"
							}
						}
					}
				},
				"extensions": {
					"type": "object",
					"description": "Step-specific additional fields; executor must ignore unknown namespaces unless explicitly supported.",
					"additionalProperties": true
				}
			}
		},
		"InputSpec": {
			"type": "object",
			"required": [
				"name",
				"type"
			],
			"additionalProperties": false,
			"properties": {
				"name": {
					"type": "string"
				},
				"type": {
					"type": "string",
					"enum": [
						"string",
						"integer",
						"number",
						"boolean",
						"array",
						"object"
					]
				},
				"source": {
					"type": "string",
					"description": "Where the executor must obtain it (ticket, repo, dashboard, previous_step, etc.)"
				},
				"constraints": {
					"type": "object",
					"additionalProperties": true
				}
			}
		},
		"OutputSpec": {
			"type": "object",
			"required": [
				"name",
				"type"
			],
			"additionalProperties": false,
			"properties": {
				"name": {
					"type": "string"
				},
				"type": {
					"type": "string",
					"enum": [
						"string",
						"integer",
						"number",
						"boolean",
						"array",
						"object"
					]
				},
				"write_to": {
					"type": "string",
					"description": "Where it must be recorded (ticket, log, registry, docs, etc.)"
				},
				"constraints": {
					"type": "object",
					"additionalProperties": true
				}
			}
		},
		"CheckSpec": {
			"type": "object",
			"required": [
				"name",
				"evidence",
				"pass_condition"
			],
			"additionalProperties": false,
			"properties": {
				"name": {
					"type": "string"
				},
				"evidence": {
					"type": "string",
					"description": "What is observed (dashboard metric, doc status, registry record, etc.)"
				},
				"pass_condition": {
					"type": "string",
					"description": "Deterministic condition (no natural language 'looks good')."
				}
			}
		},
		"AllowDenyPatterns": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"paths": {
					"type": "array",
					"items": {
						"$ref": "#/$defs/Pattern"
					}
				},
				"urls": {
					"type": "array",
					"items": {
						"$ref": "#/$defs/Pattern"
					}
				},
				"commands": {
					"type": "array",
					"items": {
						"$ref": "#/$defs/Pattern"
					}
				},
				"args": {
					"type": "object",
					"additionalProperties": {
						"$ref": "#/$defs/ArgPattern"
					}
				}
			}
		},
		"Pattern": {
			"type": "object",
			"required": [
				"pattern",
				"type"
			],
			"additionalProperties": false,
			"properties": {
				"pattern": {
					"type": "string"
				},
				"type": {
					"type": "string",
					"enum": [
						"exact",
						"glob",
						"regex"
					],
					"default": "glob"
				}
			}
		},
		"ArgPattern": {
			"type": "object",
			"required": [
				"type"
			],
			"additionalProperties": false,
			"properties": {
				"type": {
					"type": "string",
					"enum": [
						"exact",
						"glob",
						"regex",
						"range"
					],
					"default": "exact"
				},
				"pattern": {
					"type": "string"
				},
				"min": {
					"type": "number"
				},
				"max": {
					"type": "number"
				}
			}
		},
		"Metadata": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"generated_by": {
					"type": "string"
				},
				"quality_score": {
					"type": "integer",
					"minimum": 0,
					"maximum": 100
				},
				"source_context_ref": {
					"type": "string",
					"description": "Pointer to the policy/constitution/profile used."
				},
				"tags": {
					"type": "array",
					"items": {
						"type": "string"
					}
				}
			}
		}
	}
}